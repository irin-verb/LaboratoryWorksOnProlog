	run():-	console::init(), nl, nl,
		write("Введите язык "),
		H = readLine(), Язык = readLine(), nl, nl,
		студенты_языка(Язык), fail.

	run():-	console::init(), nl, nl,
        write("Введите номер зачетной книжки первого студента  "),
		Студент1 = read(), nl,
        write("Введите номер зачетной книжки второго студента "),
		Студент2 = read(),
        студент_старше(Студент1, Студент2), nl, fail. */

    run():- console::init(), nl, nl,
        write("Проекция списка всех студентов по их ФИО и языкам"), nl, nl,
        фио_язык_студента(НомЗачКн, Фио, Язык),
        write(Фио, " ", Язык), nl, fail.

    run():- console::init(), nl, nl,
        write("Списки студентов равных по возрасту"),
        студент(НомЗачКн, Фио, _, Год, _, _),
        студенты_ровесники(НомЗачКн, Фио, Год),
        nl, fail.

    run().

end implement main
goal
 mainExe::run(main::run).
